  <footer>
    <div class="container footer-box">
      <div>© <span id="year"></span> ComfortGuard HVAC Membership</div>
      <div>Built as a demo landing page for a residential HVAC preventative maintenance plan.</div>
    </div>
  </footer>

  <script>
    const toggleMonthly = document.getElementById("toggleMonthly");
    const toggleAnnual = document.getElementById("toggleAnnual");
    const heroPrice = document.getElementById("heroPrice");
    const heroPriceNote = document.getElementById("heroPriceNote");

    function setHeroPricing(mode) {
      const monthlyActive = mode === "monthly";
      toggleMonthly.classList.toggle("active", monthlyActive);
      toggleAnnual.classList.toggle("active", !monthlyActive);

      if (monthlyActive) {
        heroPrice.textContent = "$19.99";
        heroPriceNote.textContent = "per month on auto-pay";
      } else {
        heroPrice.textContent = "$229";
        heroPriceNote.textContent = "per year when prepaid";
      }
    }

    toggleMonthly.addEventListener("click", () => setHeroPricing("monthly"));
    toggleAnnual.addEventListener("click", () => setHeroPricing("annual"));

    const referralsRange = document.getElementById("referralsRange");
    const annualPriceInput = document.getElementById("annualPrice");
    const referralCountLabel = document.getElementById("referralCountLabel");
    const discountRate = document.getElementById("discountRate");
    const renewalPrice = document.getElementById("renewalPrice");
    const customerSavings = document.getElementById("customerSavings");
    const capStatus = document.getElementById("capStatus");
    const discountBar = document.getElementById("discountBar");
    const exampleList = document.getElementById("exampleList");

    function money(value) {
      return new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD"
      }).format(value);
    }

    function getDiscountPercent(referrals) {
      return Math.min(referrals * 10, 50);
    }

    function renderExamples(basePrice) {
      const rows = [0, 1, 2, 3, 4, 5];
      exampleList.innerHTML = rows.map((count) => {
        const pct = getDiscountPercent(count);
        const price = basePrice * (1 - pct / 100);
        return `<li>${count === 5 ? "5+ referrals" : `${count} ${count === 1 ? "referral" : "referrals"}`} → ${money(price)}</li>`;
      }).join("");
    }

    function updateReferralCalculator() {
      const referrals = Number(referralsRange.value);
      const annualPrice = Number(annualPriceInput.value) || 0;
      const pct = getDiscountPercent(referrals);
      const savings = annualPrice * (pct / 100);
      const discounted = annualPrice - savings;

      referralCountLabel.textContent = referrals;
      discountRate.textContent = pct + "%";
      renewalPrice.textContent = money(discounted);
      customerSavings.textContent = money(savings);
      capStatus.textContent = pct >= 50 ? "Max discount cap reached" : "Below cap";
      discountBar.style.width = pct + "%";

      renderExamples(annualPrice);
    }

    referralsRange.addEventListener("input", updateReferralCalculator);
    annualPriceInput.addEventListener("input", updateReferralCalculator);

    const deliveryCost = document.getElementById("deliveryCost");
    const planRevenue = document.getElementById("planRevenue");
    const profitReferrals = document.getElementById("profitReferrals");
    const profitReferralsLabel = document.getElementById("profitReferralsLabel");
    const discountedRevenue = document.getElementById("discountedRevenue");
    const grossProfit = document.getElementById("grossProfit");
    const grossMargin = document.getElementById("grossMargin");
    const marginStatus = document.getElementById("marginStatus");

    function setMetricClass(el, numericValue) {
      el.classList.remove("good", "warn", "bad");
      if (numericValue > 20) el.classList.add("good");
      else if (numericValue >= 0) el.classList.add("warn");
      else el.classList.add("bad");
    }

    function updateProfitCalculator() {
      const referrals = Number(profitReferrals.value);
      const cost = Number(deliveryCost.value) || 0;
      const revenue = Number(planRevenue.value) || 0;
      const pct = getDiscountPercent(referrals);
      const netRevenue = revenue * (1 - pct / 100);
      const profit = netRevenue - cost;
      const margin = netRevenue > 0 ? (profit / netRevenue) * 100 : 0;

      profitReferralsLabel.textContent = referrals;
      discountedRevenue.textContent = money(netRevenue);
      grossProfit.textContent = money(profit);
      grossMargin.textContent = margin.toFixed(1) + "%";

      setMetricClass(grossProfit, profit);
      setMetricClass(grossMargin, margin);

      let status = "Strong positive margin";
      if (profit < 0) status = "Negative on this bill";
      else if (profit < 10) status = "Near break-even";
      else if (margin < 25) status = "Moderate but acceptable";
      marginStatus.textContent = status;
    }

    profitReferrals.addEventListener("input", updateProfitCalculator);
    deliveryCost.addEventListener("input", updateProfitCalculator);
    planRevenue.addEventListener("input", updateProfitCalculator);

    document.getElementById("year").textContent = new Date().getFullYear();

    setHeroPricing("monthly");
    updateReferralCalculator();
    updateProfitCalculator();
  </script>
</body>
